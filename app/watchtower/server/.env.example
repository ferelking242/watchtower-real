# Watchtower Server — environment variables
# Copy this file to .env and fill in your values

# ── Auth ──────────────────────────────────────────────────────────────────────
# Leave empty to run without authentication (not recommended for public servers)
API_KEY=changeme

# ── Network ───────────────────────────────────────────────────────────────────
PORT=8080

# ── Extensions ────────────────────────────────────────────────────────────────
EXTENSIONS_REPO_URL=https://raw.githubusercontent.com/kodjodevf/mangayomi-extensions/main

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_MS=300000
CACHE_DIR=data/cache

# ── Preferences ───────────────────────────────────────────────────────────────
PREFS_DIR=data/prefs

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_WINDOW_MS=60000
RATE_MAX_TOKENS=60
