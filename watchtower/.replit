[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'Watchtower Flutter app — build and run on Android/iOS device. Editing extensions and Dart source code here.' && cat replit.md 2>/dev/null || echo 'replit.md not found'"

[workflows.workflow.metadata]
outputType = "console"

[agent]
expertMode = true

[nix]
channel = "stable-25_05"
