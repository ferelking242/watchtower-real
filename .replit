modules = ["nodejs-24"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Watchtower Server"

[[workflows.workflow]]
name = "Watchtower Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 node app/watchtower/server/server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
